\vspace{1ex}

Le schťma de base de donnťes suivant sera utilisť pour l'ensemble du
sujet. Il permet de gťrer les souscriptions pour un ensemble d'opťrateurs de tťlťphonie mobile.

\begin{verbatim}
FORFAIT(nomForfait, nomOperateur, prix, options)
CLIENT(id, nom, prťnom, adresse, ville, dateNaissance)
SOUSCRIPTION(id, idClient, nomForfait, dateDebut, durťeEngagement, active, numťroAttribuť)
RESILIATION(idSouscription, dateResiliation, portabilitť, idNouvelleSouscription)
\end{verbatim}

L'attribut \texttt{durťeEngagement} est un entier positif exprimant le nombre de mois d'engagement (une valeur NULL signifiť une souscription sans engagement). 
L'attribut \texttt{SOUSCRIPTION}.\texttt{active = false} indique que la souscription ŗ ťtť rťsiliťe (si \texttt{active=true} alors la souscription est en cours). Dans le cas ou une rťsiliation a ťtť faite avec portabilitť du numťro (\texttt{portabilitť=true}), l'attribut \texttt{RESILIATION}.\texttt{idNouvelleSouscription} est non NULL et indique la nouvelle souscription vers laquelle le numťro a ťtť transfťrť.

\section{AlgŤbre relationnelle et SQL (9 points)}

\begin{enumerate}

\item (SQL et algŤbre) Noms des clients qui ont souscrit un forfait avec engagement de plus de 24 mois. (1 point)

\begin{solution}\\
	AlgŤbre:\\
	$\pi_{nom, prenom}(CLIENT \underset{id=idClient}{\bowtie} \sigma_{dureeEngagement > 24}(SOUSCRIPTION))$
	\vspace{10pt}\\
	SQL:
	\begin{verbatim}
	SELECT c.nom, c.prenom
	FROM CLIENT c, SOUSCRIPTION s
	WHERE s.idClient = c.id AND s.dureeEngagement > 24;
	\end{verbatim}
\end{solution}

\item (SQL et algŤbre) Noms des clients de Paris qui ont souscris un forfait SFR aprŤs le 01/09/2017. (2 points)

\begin{solution}\\
	AlgŤbre:\\
	$\pi_{nom, prenom}((\sigma_{ville='Paris'}(CLIENT) \underset{id=idClient}{\bowtie} \sigma_{dateDebut > '01/09/2017'}(SOUSCRIPTION))\\ \underset{nomForfait}{\bowtie} \sigma_{nomOperateur='SFR'}FORFAIT)$
	\vspace{10pt}\\
	SQL:
\begin{verbatim}
SELECT c.nom, c.prenom
FROM CLIENT c, SOUSCRIPTION s, FORFAIT f
WHERE s.idClient = c.id AND f.nomForfait = s.nomForfait AND 
      c.ville = 'Paris' AND f.nomOperateur = 'SFR' AND s.dateDebut > '01/09/2017';
\end{verbatim}
\end{solution}

\item (SQL et algŤbre) Noms des clients qui n'ont jamais rťsiliť un forfait pendent la durťe d'engagement. (2 points)

\begin{solution}\\
	AlgŤbre:\\
	$R1 = \pi_{nom, prenom}(\sigma_{dateResiliation-dateDebut < dureeEngagement}(((CLIENT\;c \underset{c.id=s.idClient}{\bowtie}\\ SOUSCRIPTION\;s)  \underset{s.id=r.idSouscription}{\bowtie} RESILIATION\;r)))$\\
	$Resultat = \pi_{nom, prenom}(CLIENT) - R1$
	\vspace{10pt}\\
	SQL:
	\begin{verbatim}
	SELECT nom, prenom FROM CLIENT
	WHERE (nom, prenom) NOT IN 
         (SELECT non, prenom
          FROM CLIENT c, SOUSCRIPTION s, RESILIATION r
          WHERE s.idClient = c.id AND r.idSouscription = s.id AND 
                dateResiliation - dateDebut < dureeEngagement);
	\end{verbatim}
\end{solution}

\item (SQL seulement) Noms des opťrateurs listťs par ordre dťcroissant du nombre de souscriptions. (1 point)

\begin{solution}\\
	SQL:
	\begin{verbatim}
	SELECT nomOperateur
	FROM FORFAIT f, SOUSCRIPTION s
	WHERE f.nomForfait = s.nomForfait
	GROUP BY nomOperateur
	ORDER BY COUNT(*) DESC;
	\end{verbatim}
\end{solution}

\item (SQL seulement) Les noms des opťrateurs qui ont le maximum de rťsiliations (2 points)

\begin{solution}\\
	SQL:
	\begin{verbatim}
	SELECT nomOperateur
	FROM SOUSCRIPTION s, RESILIATION r, FORFAIT f
	WHERE s.id = r.idSouscription AND s.nomForfait = f.nomForfait
	GROUP BY nomOperateur
	HAVING COUNT(*) = (SELECT MAX(COUNT(*)
	                   FROM SOUSCRIPTION s, RESILIATION r, FORFAIT f
	                   WHERE s.id = r.idSouscription AND s.nomForfait = f.nomForfait
	                   GROUP BY nomOperateur)
	\end{verbatim}
\end{solution}

\item (AlgŤbre seulement) Les noms des client qui ont souscrit au moins un forfait pour chaque opťrateur. (1 point)

\begin{solution}\\
	AlgŤbre:\\
	$R1 = \pi_{c.id, c.nom, c.prenom, nomOperateur}(((CLIENT\;c \underset{c.id=s.idClient}{\bowtie}\\ SOUSCRIPTION\;s)  \underset{s.nomForfait=f.nomForfait}{\bowtie} FORFAIT\;f))$\\
	$Resultat = \pi_{nom, prenom}(R1 \div \pi_{nomOperateur}(FORFAIT))$
\end{solution}


\end{enumerate}

