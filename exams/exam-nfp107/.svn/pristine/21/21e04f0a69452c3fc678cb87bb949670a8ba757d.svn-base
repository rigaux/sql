\vspace{1ex}
Soit la base de données suivante permettant de gérer des tournois de tennis:
\begin{verbatim}
JOUEUR(id, nom, prénom, age, pays)
TERRAIN(id, capacité, ville)
MATCH(id, idJoueur1, idJoueur2, idTerrain, dateMatch, gagnant, nbSpectateurs, nomTurnoi)
BILLET(idMatch, numeroSpectateur, nomSpectateur, prenomSpectateur, prixBillet)
\end{verbatim}
L'attribut \texttt{MATCH(gagnant)} est un INTEGER qui indique le joueur gagnant: 1 pour le 1er joueur ou 2 pour le 2eme joueur. L'attribut \texttt{TERRAIN(capacité)} désigne le nombre de places du terrain.


\section{Algèbre relationnelle et SQL (10 points)}

1. Pour la table MATCH identifier les clés primaires et étrangères. (0,5 points)

\begin{solution}\\
Clé primaire: (idJoueur1, idJoueur2, idTerrain, dateMatch)\\
Clés étrangères : idJoueur1 $\rightarrow$ JOUEUR(idJoueur), idJoueur2 $\rightarrow$ JOUEUR(idJoueur), idTerrain $\rightarrow$ TERRAIN(id)
\end{solution}

2. Donner la commande SQL pour créer la table MATCH. (0,5 points)

\begin{solution}
\begin{verbatim}
CREATE TABLE MATCH (
    idJoueur1 NUMBER,
    idJoueur2 NUMBER,
    idTerrain NUMBER,
    dateMatch DATE,
    gagnant INTEGER,
    nbSpectateurs NUMBER,
    prixBillet NUMBER,
    CONSTRAINT pkMatch PRIMARY KEY (idJoueur1, idJoueur2, idTerrain, dateMatch),
    CONSTRAINT fkidJoueur1 FOREIGN KEY idJoueur1 REFERENCES JOUEUR(id),
    CONSTRAINT fkidJoueur2 FOREIGN KEY idJoueur2 REFERENCES JOUEUR(id),
    CONSTRAINT fkidTerrain FOREIGN KEY idTerrain REFERENCES TERRAIN(id)
)
\end{verbatim}
\end{solution}

3. (Algèbre et SQL) Noms des joueurs français âgés de plus de 30 ans qui ont joué un match le 01/02/2017. (1 point)

\begin{solution}

$\pi_{nom}(\sigma_{age > 30 \wedge pays = 'France' \wedge dateMatch = '01/02/2017'}(JOUEUR \underset{id=idJoueur1 \vee id=idJoueur2}{\bowtie MATCH}))$

\begin{verbatim}
SELECT nom
FROM JOUEUR, MATCH
WHERE (id = idJoueur1 OR id = idJoueur2) AND age > 30 AND 
       pays = 'France' AND dateMatch = '01/02/2017';
\end{verbatim}

\end{solution}

4. (Algèbre et SQL) Noms des joueurs français qui ont gagné un match dans la ville de Rennes. (2 points)

\begin{solution}

$\pi_{nom}(\sigma_{pays='France' \wedge ville = 'Rennes'}(JOUEUR \underset{(id=idJoueur1 \wedge gagnant = 1) \vee (id=idJoueur2 \wedge gagnant = 2)}{\bowtie} (TERRAIN \underset{id = idTerrain}{\bowtie} MATCH)))$

\begin{verbatim}
SELECT nom
FROM JOUEUR, TERRAIN, MATCH
WHERE ((id = idJoueur1 AND gagnant = 1) OR (id = idJoueur2 AND gagnant = 2)) 
      AND id = idTerrain AND pays = 'France' AND ville = 'Rennes';
\end{verbatim}

\end{solution}

5. (Algèbre et SQL) Noms des spectateurs qui ont participé à un match de Rafael Nadal joué à Madrid le 01/02/2017. (2 points)

\begin{solution}

$\pi_{nomSpectateur}(BILLET \underset{idMatch = MATCH.id}{\bowtie}(\sigma_{nom = 'Nadal' \wedge prenom = 'Rafael'}(JOUEUR)\\ \underset{id=idJoueur1 \vee id=idJoueur2}{\bowtie} (\sigma_{ville = 'Madrid'}(TERRAIN) \underset{id = idTerrain}{\bowtie} \sigma_{date='01/02/2017'}MATCH)))$

\begin{verbatim}
SELECT nom
FROM JOUEUR j, TERRAIN t, MATCH m, BILLET b
WHERE (j.id = idJoueur1 OR j.id = idJoueur2) AND m.id = idMatch AND
      t.id = idTerrain AND j.nom = 'Nadal' AND j.prenom = 'Rafael' AND 
      ville = 'Madrid' AND date='01/02/2017';
\end{verbatim}
\end{solution}

6. (Algèbre et SQL) Noms des terrains qui n'ont jamais été remplis à 100\% de leur capacité. (1 points)

\begin{solution}\\
$R = \pi_{id, nomTerrain}(\sigma_{capacite=nbSpectateurs}(TERRAIN \underset{id = idTerrain}{\bowtie} MATCH))$

$Resultat = \pi_{nomTerrain}(\pi_{id, nomTerrain}(TERRAIN) - R)$

\begin{verbatim}
SELECT nomTerrain FROM TERRAIN
WHERE id NOT IN 
    (SELECT id
    FROM TERRAIN, MATCH
    WHERE id = idTerrain AND capacite = nbSpectateurs)
\end{verbatim}
\end{solution}

7. (SQL seulement) Les noms des terrains qui ont fait le plus d'entrées d'argent. (2 points)

\begin{solution}
\begin{verbatim}
SELECT id, nomTerrain
FROM TERRAIN t, MATCH m, BILLET b
WHERE t.id = m.idTerrain AND m.id = b.idMatch
GROUP BY t.id
HAVING SUM(prixBillet) = 
    (SELECT id, MAX(SUM(prixBillet))
    FROM TERRAIN t, MATCH m, BILLET b
    WHERE t.id = m.idTerrain AND m.id = b.idMatch
    GROUP BY t.id)
\end{verbatim}
\end{solution}

8. (Algèbre seulement) Les noms des spectateurs qui ont vu tous les matches de Rafael Nadal. (1 point)

\begin{solution}\\
	
	$S = \pi_{idMatch}(MATCH \underset{idJoueur1 = id \vee idJoueur1 = id}{\bowtie} \sigma_{nom='Nadal' \wedge prenom='Rafael'}(JOUEUR))$
	
	$Resultat = \pi_{nom}(\pi_{nomSpectateur, idMatch}(BILLET) \div S)$

\end{solution}	




