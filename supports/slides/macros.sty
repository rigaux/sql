% Dessiner des Arbresme
%\psset{armB=5mm,angleA=90,angleB=-90,levelsep=2cm,treesep=5mm}
\psset{levelsep=2cm}
\newrgbcolor{cblue}{0.4 0.4 1.6}
\def\MyShadowBox#1#2{%
  \textcolor{black}{\psshadowbox[framearc=.3]{%
    \shortstack[c]{\texttt{\shortstack[c]{#1}}\\{#2}}}}}
\def\MyFrameBox#1#2{%
  \psovalbox[framearc=.3,fillstyle=solid,fillcolor=white]{%
    \shortstack[c]{\textcolor{black}{\texttt{\shortstack[c]{#1}}}\\ 
               \textcolor{black}{#2}}}}
\def\MySolidShadowBox#1#2{%
  \psshadowbox[framearc=.3,fillstyle=solid,fillcolor=cblue]{%
    \shortstack[c]{\texttt{\shortstack[c]{#1}}\\\shortstack[c]\small{#2}}}}
\def\NoeudArbre#1#2#3{%
  \pstree{\Tr[name=#1]{\MyShadowBox{#2}{}}}{#3}
}
\newcommand{\entreeArbreB}[1]{\psovalbox{\textcolor{red}{#1}}}
