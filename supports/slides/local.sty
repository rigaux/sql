\newcommand{\myfigure}[1]{\begin{center}
%BEGIN IMAGE
  \epsfxsize=10cm
  \epsfbox{#1}
%END IMAGE
%HEVEA\imageflush
\end{center}
}

\newcommand{\mywidthfigure}[2]{\begin{center}
%BEGIN IMAGE
  \epsfxsize=#1
  \epsfbox{#2}
%END IMAGE
%HEVEA\imageflush
\end{center}
}

\newcommand{\myheightfigure}[2]{\begin{center}
%BEGIN IMAGE
  \epsfysize=#1
  \epsfbox{#2}
%END IMAGE
%HEVEA\imageflush
\end{center}
}

