%
% by modifying \fbox in latex.tex
% \Underline & \Underbar
%
\def\Underline#1{%
    \leavevmode%
    \setbox\@tempboxa\hbox{#1}%
    \@tempdima1pt
    \advance\@tempdima 3pt
    \advance\@tempdima \dp\@tempboxa
    \hbox{\lower \@tempdima%
          \hbox{\vbox{\hbox{\vbox{\box\@tempboxa\vskip3pt}}%
                      \hrule height1pt}}}}

% from plain.tex
\def\Underbar#1{$\setbox\z@\hbox{#1}\dp\z@\z@
  \m@th \Underline{\box\z@}$}
