% Pour la recriture

\usepackage{pstricks,pst-node,pst-text,pst-3d,pst-tree,pst-grad}
\def\MyShadowBox#1#2{%
  \textcolor{black}{\psshadowbox[framearc=.3]{%
    \shortstack[c]{\texttt{\shortstack[c]{#1}}\\{#2}}}}}
\def\Database#1#2{%
  \Tr[name=#1]{\MyFrameBox{\textit{#1}}{#2}}}
\def\IteratorSansNom#1#2#3{%
  \pstree{\Tr{\MyShadowBox{\textbf{{\sc #1}}}{\textit{#2}}}}{#3}
}
\def\MyFrameBox#1#2{%
  \psovalbox[framearc=.3,fillstyle=solid,fillcolor=white]{%
    \shortstack[c]{\textcolor{black}{\texttt{\shortstack[c]{#1}}}\\ 
               \textcolor{black}{#2}}}}
\def\IteratorSansNom#1#2#3{%
  \pstree{\Tr{\MyShadowBox{\textbf{{\sc #1}}}{\textit{#2}}}}{#3}
}